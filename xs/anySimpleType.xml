<?xml version="1.0" encoding="UTF-8"?>
<test-set xmlns="http://www.w3.org/2010/09/qt-fots-catalog" name="xs-anySimpleType">
   <description>Tests features of XSD 1.1 anySimpleType</description>

   <test-case name="xs-anySimpleType-001">
      <description>Construct from a string.</description>
      <created by="Sheila Thomson" on="2026-02-11"/>
      <test>xs:anySimpleType("x")</test>
   	<result>
   		<error code="XPST0017"/>
   	</result>
   </test-case>
	
	<test-case name="xs-anySimpleType-002">
		<description>Construct from an integer.</description>
		<created by="Sheila Thomson" on="2026-02-12"/>
		<test>xs:anySimpleType(1)</test>
		<result>
			<error code="XPST0017"/>
		</result>
	</test-case>
	
	<test-case name="xs-anySimpleType-003">
		<description>Wrong arity.</description>
		<created by="Michael Kay" on="2026-03-04"/>
		<test>xs:anySimpleType()</test>
		<result>
			<error code="XPST0017"/>
		</result>
	</test-case>
	
	<test-case name="xs-anySimpleType-004">
		<description>Wrong arity.</description>
		<created by="Michael Kay" on="2026-03-04"/>
		<test>xs:anySimpleType("a", "b")</test>
		<result>
			<error code="XPST0017"/>
		</result>
	</test-case>
	
	<test-case name="xs-anySimpleType-010">
		<description>Instance of test.</description>
		<created by="Michael Kay" on="2026-03-04"/>
		<test>"a" instance of xs:anySimpleType</test>
		<result>
			<error code="XPST0051"/>
		</result>
	</test-case>
	
	<test-case name="xs-anySimpleType-011">
		<description>Instance of test.</description>
		<created by="Michael Kay" on="2026-03-04"/>
		<dependency type="spec" value="XQ40+"/>
		<test>attribute #a {123} instance of attribute(*, xs:anySimpleType)</test>
		<result>
			<assert-true/>
		</result>
	</test-case>


</test-set>
