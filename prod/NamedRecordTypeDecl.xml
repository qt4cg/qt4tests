<?xml version="1.0" encoding="us-ascii"?>
<test-set xmlns="http://www.w3.org/2010/09/qt-fots-catalog" name="prod-recordTypeDecl"
          covers-40="PR1355">
   <description>Tests for record type declarations: 4.0 proposal</description>
 
   
   <environment name="user-defined-types">
      <schema uri="http://www.w3.org/XQueryTest/userDefinedTypes" file="../docs/userdefined.xsd">
         <description>A schema user defined types and constructor tests</description>
         <created by="Anonymous" on="2006-04-03"/>
      </schema>   
   </environment>
         
   <dependency type="spec" value="XQ40+"/>
      
   <test-case name="recordTypeDecl-001">
      <description>local record type, used in instance of</description>
      <created by="Michael Kay" on="2026-07-06"/>
      <test><![CDATA[
         declare record local:R (a, b);
      	let $r as local:R := {'a':1, 'b':2}
      	return $r instance of local:R
      ]]></test>
      <result>
         <assert-true/>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-002">
      <description>local record type, used in instance of with occurrence indicator</description>
      <created by="Michael Kay" on="2026-07-06"/>
      <test><![CDATA[
         declare record local:R ('first name', "last name");
      	let $r as local:R* := ({'first name':1, 'last name':2}, {'first name':11, 'last name':22})
      	return $r instance of local:R+
      ]]></test>
      <result>
         <assert-true/>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-003">
      <description>local record type, instance not coerced to type</description>
      <created by="Michael Kay" on="2026-07-06"/>
      <test><![CDATA[
         declare record local:R (a, b);
      	let $r := {'a':1, 'b':2}
      	return $r instance of local:R
      ]]></test>
      <result>
         <assert-false/>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-004">
      <description>local record type, invalid syntax</description>
      <created by="Michael Kay" on="2026-07-06"/>
      <test><![CDATA[
         declare record local:R (*);
      	let $r := {'a':1, 'b':2}
      	return $r instance of local:R
      ]]></test>
      <result>
         <assert-false/>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-005">
      <description>local record type, initial values</description>
      <created by="Michael Kay" on="2026-07-06"/>
      <test><![CDATA[
         declare record local:R (a := 5, b := 6);
      	let $r := {'a':1, 'b':2}
      	return $r instance of local:R
      ]]></test>
      <result>
         <assert-false/>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-005">
      <description>local record type, declared types plus initial values</description>
      <created by="Michael Kay" on="2026-07-06"/>
      <test><![CDATA[
         declare record local:R (a as xs:integer := 5, b as xs:string := 'xyz');
      	let $r := {'a':1, 'b':'pqr'}
      	return $r instance of local:R
      ]]></test>
      <result>
         <assert-false/>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-006">
      <description>local record type, constructor function</description>
      <created by="Michael Kay" on="2026-07-06"/>
      <test><![CDATA[
         declare record local:R (a as xs:integer := 5, b as xs:string := 'xyz');
      	let $r := local:R(7, "abba")
      	return [$r?a, $r?b]
      ]]></test>
      <result>
         <assert-deep-eq>[7, "abba"]</assert-deep-eq>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-007">
      <description>local record type, constructor function with keyword parameters</description>
      <created by="Michael Kay" on="2026-07-06"/>
      <test><![CDATA[
         declare record local:R (a as xs:integer := 5, b as xs:string := 'xyz');
      	let $r := local:R(b := "saas", a := 42)
      	return [$r?a, $r?b]
      ]]></test>
      <result>
         <assert-deep-eq>[42, "saas"]</assert-deep-eq>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-008">
      <description>local record type, constructor function with defaulted parameters</description>
      <created by="Michael Kay" on="2026-07-06"/>
      <test><![CDATA[
         declare record local:R (a as xs:integer := 5, b as xs:string := 'xyz');
      	let $r := local:R(a := 30)
      	return [$r?a, $r?b]
      ]]></test>
      <result>
         <assert-deep-eq>[30, "xyz"]</assert-deep-eq>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-009">
      <description>local record type, forwards reference to constructor function</description>
      <created by="Michael Kay" on="2026-07-06"/>
      <test><![CDATA[        
      	declare variable $r := local:R(a := 30);
      	declare record local:R (a as xs:integer := 5, b as xs:string := 'xyz');
      	return [$r?a, $r?b]
      ]]></test>
      <result>
         <assert-deep-eq>[30, "xyz"]</assert-deep-eq>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-010">
      <description>local record type, forwards reference to constructor function and type</description>
      <created by="Michael Kay" on="2026-07-06"/>
      <test><![CDATA[        
      	declare variable $r := local:R(a := 30);
      	declare function local:F($x) { $x instance of local:R and $x?a = 30 and $x?b = 'xyz');
      	declare record local:R (a as xs:integer := 5, b as xs:string := 'xyz');
      	return local:F($r)
      ]]></test>
      <result>
         <assert-true/>
      </result>
   </test-case>
   
