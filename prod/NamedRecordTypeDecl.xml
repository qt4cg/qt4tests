   <test-case name="recordTypeDecl-016" covers-40="PR1908">
      <description>Forwards references are allowed</description>
      <created by="Michael Kay" on="2025-03-31"/>
      <test><![CDATA[
         declare variable $cplx as local:complex-number := {'real': 0, 'imag': 1};
         declare record local:complex-number as map(*);
      	`{$cplx?real} + {$cplx?imag}i`
      ]]></test>
      <result>
         <assert-eq>"0 + 1i"</assert-eq>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-017" covers-40="PR1908">
      <description>Self-references are not allowed</description>
      <created by="Michael Kay" on="2025-03-31"/>
      <test><![CDATA[
         declare variable $cplx as local:complex-number := {'real': 0, 'imag': 1};
         declare record local:complex-number as map(xs:string, local:complex-number);
      	`{$cplx?real} + {$cplx?imag}i`
      ]]></test>
      <result>
         <error code="XQST0140"/>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-018" covers-40="PR1908">
      <description>Mutual recursion is not allowed</description>
      <created by="Michael Kay" on="2025-03-31"/>
      <test><![CDATA[
         declare record local:yin as map(xs:string, local:yan);
         declare record local:yan as map(xs:string, local:yin);
      	declare variable $x as local:yin external;
      	$x
      ]]></test>
      <result>
         <error code="XQST0140"/>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-019" covers-40="PR1908">
      <description>Forwards references are allowed: multiple indirection</description>
      <created by="Michael Kay" on="2026-06-30"/>
      <test><![CDATA[
         declare variable $cplx as local:complex-number := {'real': 0, 'imag': 1};
         declare record local:complex-number as local:complex-number2;
         declare record local:complex-number2 as local:complex-number3;
         declare record local:complex-number3 as local:complex-number4;
         declare record local:complex-number4 as local:complex-number5;
         declare record local:complex-number5 as map(*);
      	`{$cplx?real} + {$cplx?imag}i`
      ]]></test>
      <result>
         <assert-eq>"0 + 1i"</assert-eq>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-020" covers-40="PR1908">
      <description>Map key type must be atomic</description>
      <created by="Michael Kay" on="2026-06-30"/>
      <test><![CDATA[
         declare variable $cplx as map(local:key-type, item()*) := {'real': 0, 'imag': 1};
         declare record local:key-type as element(*);
      	`{$cplx?real} + {$cplx?imag}i`
      ]]></test>
      <result>
         <error code="XPST0152"/>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-021" covers-40="PR1908">
      <description>Map key type must be atomic</description>
      <created by="Michael Kay" on="2026-06-30"/>
      <test><![CDATA[
         declare variable $cplx as map(local:key-type, item()*) := {'real': 0, 'imag': 1};
         declare record local:key-type as xs:string;
      	`{$cplx?real} + {$cplx?imag}i`
      ]]></test>
      <result>
         <assert-eq>"0 + 1i"</assert-eq>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-022" covers-40="PR1908">
      <description>Map key type must be atomic</description>
      <created by="Michael Kay" on="2026-06-30"/>
      <test><![CDATA[
         declare variable $cplx as map(local:key-type, item()*) := {'real': 0, 'imag': 1};
         declare record local:key-type as enum('real', 'imag');
      	`{$cplx?real} + {$cplx?imag}i`
      ]]></test>
      <result>
         <assert-eq>"0 + 1i"</assert-eq>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-023" covers-40="PR1908">
      <description>Forward reference in let clause</description>
      <created by="Michael Kay" on="2026-06-30"/>
      <test><![CDATA[
         declare function local:f() {
            let $x as local:x-type := xs:date('2026-06-30')
            return string($x)
         };   
         declare record local:x-type as (xs:date | xs:time);
      	local:f()
      ]]></test>
      <result>
         <assert-eq>'2026-06-30'</assert-eq>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-024" covers-40="PR1908">
      <description>Forward reference in group by clause</description>
      <created by="Michael Kay" on="2026-06-30"/>
      <test><![CDATA[
         declare function local:f() {
            for $x in 1 to 1000
            group by $g as local:group-type+ := $x mod 50
            return count($x)
         };   
         declare record local:group-type as xs:long;
      	local:f() => distinct-values()
      ]]></test>
      <result>
         <assert-eq>20</assert-eq>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-025" covers-40="PR1908">
      <description>Forward reference in cast expression</description>
      <created by="Michael Kay" on="2026-06-30"/>
      <test><![CDATA[
         declare function local:f() {
            '2026-06-30' cast as local:x-type
         };   
         declare record local:x-type as (xs:date | xs:time);
      	local:f()
      ]]></test>
      <result>
         <assert-eq>xs:date('2026-06-30')</assert-eq>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-026" covers-40="PR1908">
      <description>Forward reference in constructor function</description>
      <created by="Michael Kay" on="2026-06-30"/>
      <test><![CDATA[
         declare function local:f() {
             local:x-type('2026-06-30')
         };   
         declare record local:x-type as (xs:date | xs:time);
      	local:f()
      ]]></test>
      <result>
         <assert-eq>xs:date('2026-06-30')</assert-eq>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-027" covers-40="PR1908">
      <description>Error, duplicate type names</description>
      <created by="Michael Kay" on="2026-06-30"/>
      <test><![CDATA[  
         declare record local:a as (xs:date | xs:time);
         declare record local:b as (xs:date | xs:time);
         declare record local:c as (xs:date | xs:time);
         declare record local:d as (xs:date | xs:time);
         declare record local:elephant as (xs:date | xs:time);
         declare record local:f as (xs:date | xs:time);
         declare record local:g as (xs:date | xs:time);
         declare record local:h as (xs:date | xs:time);
         declare record local:i as (xs:date | xs:time);
         declare record local:j as (xs:date | xs:time);
         declare record local:elephant as (xs:date | xs:time | xs:dateTime | xs:integer);
      	let $x as local:elephant := trunk(1 to 100) return $x + 1
      ]]></test>
      <result>
         <error code="XQST0146"/>
      </result>
   </test-case>
   
   <test-case name="recordTypeDecl-028">
