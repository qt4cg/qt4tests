<test-set xmlns="http://www.w3.org/2010/09/qt-fots-catalog" name="bin-is-bit-set" covers-40="PR2662">
  <description>Tests for the bin:and function</description>
  
  <environment name="EXPath-binary-bitwise">
    <namespace prefix="bin" uri="http://expath.org/ns/binary"/>
    <namespace prefix="errbin" uri="http://expath.org/ns/binary"/>
    <param name="empty.bin" select="xs:base64Binary('')"/>
    <param name="a" select="xs:base64Binary(xs:hexBinary('F00F'))"/>
    <param name="b" select="xs:base64Binary(xs:hexBinary('0FF0'))"/>
    <param name="c" select="xs:base64Binary(xs:hexBinary('0FABCD'))"/>
  </environment>
  
  <environment name="binary">
    <namespace prefix="bin" uri="http://expath.org/ns/binary"/>
  </environment>
  
  <dependency type="feature" value="binary"/>
  <dependency type="spec" value="XP40+ XQ40+"/>
  
  <test-case name="is-bit-set-001">
    <description>is-bit-set on single byte</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:is-bit-set(bin:hex('FF'), 0)</test>
    <result>
      <assert-true/>
    </result>
  </test-case>
  
  <test-case name="is-bit-set-002">
    <description>is-bit-set on single byte</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:is-bit-set(bin:hex('0F'), 0)</test>
    <result>
      <assert-false/>
    </result>
  </test-case>
  
  <test-case name="is-bit-set-003">
    <description>is-bit-set on single byte</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:is-bit-set(bin:hex('00'), 5)</test>
    <result>
      <assert-false/>
    </result>
  </test-case>
  
  <test-case name="is-bit-set-004">
    <description>is-bit-set on single byte</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:is-bit-set(bin:hex('0F'), 5)</test>
    <result>
      <assert-true/>
    </result>
  </test-case>
  
  <test-case name="is-bit-set-005">
    <description>is-bit-set on single byte</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:is-bit-set(bin:hex('01'), 7)</test>
    <result>
      <assert-true/>
    </result>
  </test-case>
  
  <test-case name="is-bit-set-006">
    <description>is-bit-set on single byte</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:is-bit-set(bin:hex('02'), 7)</test>
    <result>
      <assert-false/>
    </result>
  </test-case>
  
  <test-case name="is-bit-set-007">
    <description>is-bit-set on single byte, out of range</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:is-bit-set(bin:hex('02'), -1)</test>
    <result>
      <error code="Q{http://expath.org/ns/binary}index-out-of-range"/>
    </result>
  </test-case>
  
  <test-case name="is-bit-set-008">
    <description>is-bit-set on single byte, out of range</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:is-bit-set(bin:hex('02'), 8)</test>
    <result>
      <error code="Q{http://expath.org/ns/binary}index-out-of-range"/>
    </result>
  </test-case>
  
  <test-case name="is-bit-set-009">
    <description>is-bit-set on four bytes</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:is-bit-set(bin:hex('F000F000'), 0)</test>
    <result>
      <assert-true/>
    </result>
  </test-case>
  
  <test-case name="is-bit-set-010">
    <description>is-bit-set on four bytes</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:is-bit-set(bin:hex('00010001'), 31)</test>
    <result>
      <assert-true/>
    </result>
  </test-case>
  
  <test-case name="is-bit-set-011">
    <description>is-bit-set on four bytes</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:is-bit-set(bin:hex('F000F000'), 4)</test>
    <result>
      <assert-false/>
    </result>
  </test-case>
  
  <test-case name="is-bit-set-012">
    <description>is-bit-set on single byte</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:is-bit-set(bin:hex('00010001'), 30)</test>
    <result>
      <assert-false/>
    </result>
  </test-case>
  
  <test-case name="is-bit-set-013">
    <description>is-bit-set on 32 bytes</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:is-bit-set(bin:hex('0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001'), 0)</test>
    <result>
      <assert-false/>
    </result>
  </test-case>
  
  <test-case name="is-bit-set-014">
    <description>is-bit-set on 32 bytes</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:is-bit-set(bin:hex('0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001'), 64)</test>
    <result>
      <assert-false/>
    </result>
  </test-case>
  
  <test-case name="is-bit-set-015">
    <description>is-bit-set on 32 bytes</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:is-bit-set(bin:hex('0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001'), 63)</test>
    <result>
      <assert-true/>
    </result>
  </test-case>
  
  <test-case name="is-bit-set-016">
    <description>is-bit-set on 32 bytes</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:is-bit-set(bin:hex('0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001'), 255)</test>
    <result>
      <assert-true/>
    </result>
  </test-case>
  
  <test-case name="is-bit-set-017">
    <description>is-bit-set on 4096 bytes</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test>
      let $bbb := bin:join(for $i in 1 to 1024 return bin:pack-integer($i, 4))
      return (bin:is-bit-set($bbb, 31), bin:is-bit-set($bbb, 63), bin:is-bit-set($bbb, 95), bin:is-bit-set($bbb, 4095))
    </test>
    <result>
      <assert-deep-eq>true(), false(), true(), false()</assert-deep-eq>
    </result>
  </test-case>
  
</test-set>