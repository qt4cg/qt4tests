  </test-case>
  
  <test-case name="bin-rotate-010">
    <description>bitwise-rotate right by 1 bit</description>
    <created by="Michael Kay" on="2026-06-20"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> xs:hexBinary(bin:rotate(bin:hex('F00F'), -1)) </test>
    <result>
      <assert-eq>xs:hexBinary("F807")</assert-eq>
    </result>
  </test-case>
  
  <test-case name="bin-rotate-011">
