  <test-case name="bin-rotate-021">
    <description>Test for the rotate function.</description>
    <created by="Michael Kay" on="2026-06-20"/>
    <environment ref="binary"/>
    <test>xs:hexBinary(bin:rotate((), 1))</test>
    <result>
      <assert-empty/>
    </result>
  </test-case>
  
  <test-case name="bin-rotate-022">
    <description>Test for the rotate function.</description>
    <created by="Michael Kay" on="2026-06-20"/>
    <environment ref="binary"/>
    <test>xs:hexBinary(bin:rotate(xs:base64Binary(xs:hexBinary("77")), 0))</test>
    <result>
      <assert-eq>xs:hexBinary("77")</assert-eq>
    </result>
  </test-case>
  
  <test-case name="bin-rotate-023">
    <description>Test for the rotate function.</description>
    <created by="Michael Kay" on="2026-06-20"/>
    <environment ref="binary"/>
    <test>xs:hexBinary(bin:rotate(xs:base64Binary(xs:hexBinary("33")), 1))</test>
    <result>
      <assert-eq>xs:hexBinary("66")</assert-eq>
    </result>
  </test-case>
  
  <test-case name="bin-rotate-024">
    <description>Test for the rotate function.</description>
    <created by="Michael Kay" on="2026-06-20"/>
    <environment ref="binary"/>
    <test>xs:hexBinary(bin:rotate(xs:base64Binary(xs:hexBinary("66")), -1))</test>
    <result>
      <assert-eq>xs:hexBinary("33")</assert-eq>
    </result>
  </test-case>
  
  <test-case name="bin-rotate-025">
    <description>Test for the rotate function.</description>
    <created by="Michael Kay" on="2026-06-20"/>
    <environment ref="binary"/>
    <test>
      let $rot := bin:join((1 to 1000) =!> bin:pack-integer(4)) => bin:rotate(500 * 32)
      for $i in 0 to 999 return bin:unpack-integer($rot, $i*4, 4)
    </test>
    <result>
      <assert-deep-eq>(501 to 1000, 1 to 500)</assert-deep-eq>
    </result>
  </test-case>
  
  <test-case name="bin-rotate-026">
    <description>Test for the rotate function.</description>
    <created by="Michael Kay" on="2026-06-20"/>
    <environment ref="binary"/>
    <test>
      let $rot := bin:join((1 to 1000) =!> bin:pack-integer(4)) => bin:rotate(-500 * 32)
      for $i in 0 to 999 return bin:unpack-integer($rot, $i*4, 4)
    </test>
    <result>
      <assert-deep-eq>(501 to 1000, 1 to 500)</assert-deep-eq>
    </result>
  </test-case>
  
 
  
</test-set>