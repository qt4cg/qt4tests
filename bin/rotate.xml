<test-set xmlns="http://www.w3.org/2010/09/qt-fots-catalog" name="bin-rotate"  covers-40="PR2662">
  <description>Tests for the bin:rotate function</description>
  
  <environment name="EXPath-binary-bitwise">
    <namespace prefix="bin" uri="http://expath.org/ns/binary"/>
    <namespace prefix="binJAVA" uri="java:org.expath.ns.binary.EXPathBinary"/>
    <namespace prefix="errbin" uri="http://expath.org/ns/binary"/>
    <param name="empty.bin" select="xs:base64Binary('')"/>
    <param name="a" select="xs:base64Binary(xs:hexBinary('F00F'))"/>
    <param name="b" select="xs:base64Binary(xs:hexBinary('0FF0'))"/>
    <param name="c" select="xs:base64Binary(xs:hexBinary('0FABCD'))"/>
  </environment>
  
  <environment name="binary">
    <namespace prefix="bin" uri="http://expath.org/ns/binary"/>
  </environment>
  
  <dependency type="feature" value="binary"/>
  <dependency type="spec" value="XP40+ XQ40+"/>
  
  <test-case name="bin-rotate-001">
    <description>bitwise-rotate on empty sequence</description>
    <created by="Michael Kay" on="2026-06-20"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:rotate((),5) </test>
    <result>
      <assert-empty/>
    </result>
  </test-case>
  
  <test-case name="bin-rotate-002">
    <description>bitwise-rotate by 0 bits</description>
    <created by="Michael Kay" on="2026-06-20"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:rotate($a,0) </test>
    <result>
      <all-of>
        <assert-type>xs:base64Binary</assert-type>
        <assert-eq>xs:base64Binary(xs:hexBinary("F00F"))</assert-eq>
      </all-of>
    </result>
  </test-case>
  
  <test-case name="bin-rotate-003">
    <description>bitwise-rotate left by 1 bit</description>
    <created by="Michael Kay" on="2026-06-20"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> xs:hexBinary(bin:rotate($a,1)) </test>
    <result>
      <assert-eq>xs:hexBinary("E01F")</assert-eq>
    </result>
  </test-case>
  
  <test-case name="bin-rotate-004">
    <description>bitwise-rotate left by 4 bits</description>
    <created by="Michael Kay" on="2026-06-20"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> xs:hexBinary(bin:rotate(bin:hex('F00F'), 4)) </test>
    <result>
      <assert-eq>xs:hexBinary("00FF")</assert-eq>
    </result>
  </test-case>
  
  <test-case name="bin-rotate-005">
    <description>bitwise-rotate left by 8 bits</description>
    <created by="Michael Kay" on="2026-06-20"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> xs:hexBinary(bin:rotate(bin:hex('F00F'), 8)) </test>
    <result>
      <assert-eq>xs:hexBinary("0FF0")</assert-eq>
    </result>
  </test-case>
  
  <test-case name="bin-rotate-006">
    <description>bitwise-rotate left by 9 bits</description>
    <created by="Michael Kay" on="2026-06-20"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> xs:hexBinary(bin:rotate(bin:hex('F00F'), 9)) </test>
    <result>
      <assert-eq>xs:hexBinary("1FE0")</assert-eq>
    </result>
  </test-case>
  
  <test-case name="bin-rotate-007">
    <description>bitwise-rotate left by 12 bits</description>
    <created by="Michael Kay" on="2026-06-20"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> xs:hexBinary(bin:rotate(bin:hex('F00F'), 12)) </test>
    <result>
      <assert-eq>xs:hexBinary("FF00")</assert-eq>
    </result>
  </test-case>
  
  <test-case name="bin-rotate-008">
    <description>bitwise-rotate left by 16 bits</description>
    <created by="Michael Kay" on="2026-06-20"/>
