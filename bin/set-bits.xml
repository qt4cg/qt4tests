<test-set xmlns="http://www.w3.org/2010/09/qt-fots-catalog" name="set-bits" covers-40="PR2662">
  <description>Tests for the bin:and function</description>
  
  <environment name="EXPath-binary-bitwise">
    <namespace prefix="bin" uri="http://expath.org/ns/binary"/>
    <namespace prefix="errbin" uri="http://expath.org/ns/binary"/>
    <param name="empty.bin" select="xs:base64Binary('')"/>
    <param name="a" select="xs:base64Binary(xs:hexBinary('F00F'))"/>
    <param name="b" select="xs:base64Binary(xs:hexBinary('0FF0'))"/>
    <param name="c" select="xs:base64Binary(xs:hexBinary('0FABCD'))"/>
  </environment>
  
  <environment name="binary">
    <namespace prefix="bin" uri="http://expath.org/ns/binary"/>
  </environment>
  
  <dependency type="feature" value="binary"/>
  <dependency type="spec" value="XP40+ XQ40+"/>
  
  <test-case name="set-bits-001">
    <description>set-bits on single byte</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:set-bits(bin:hex('FF'), 7, false())</test>
    <result>
      <assert-eq>bin:hex('FE')</assert-eq>
    </result>
  </test-case>
  
  <test-case name="set-bits-002">
    <description>set-bits on single byte</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:set-bits(bin:hex('0F'), 0, true())</test>
    <result>
      <assert-eq>bin:hex('8F')</assert-eq>
    </result>
  </test-case>
  
  <test-case name="set-bits-003">
    <description>set-bits on single byte</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:set-bits(bin:hex('00'), 0 to 7, true())</test>
    <result>
      <assert-eq>bin:hex('FF')</assert-eq>
    </result>
  </test-case>
  
  <test-case name="set-bits-004">
    <description>set-bits on single byte</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:set-bits(bin:hex('0F'), 0 to 7, true())</test>
    <result>
      <assert-eq>bin:hex('FF')</assert-eq>
    </result>
  </test-case>
  
  <test-case name="set-bits-005">
    <description>set-bits on single byte</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:set-bits(bin:hex('01'), (), true())</test>
    <result>
      <assert-eq>bin:hex('01')</assert-eq>
    </result>
  </test-case>
  
  <test-case name="set-bits-006">
    <description>set-bits on single byte</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:set-bits(bin:hex('02'), 6 to 7, true())</test>
    <result>
      <assert-eq>bin:hex('03')</assert-eq>
    </result>
  </test-case>
  
  <test-case name="set-bits-007">
    <description>set-bits on single byte, out of range</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:set-bits(bin:hex('02'), -1, true())</test>
    <result>
      <error code="Q{http://expath.org/ns/binary}index-out-of-range"/>
    </result>
  </test-case>
  
  <test-case name="set-bits-008">
    <description>set-bits on single byte, out of range</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:set-bits(bin:hex('02'), 8, false())</test>
    <result>
      <error code="Q{http://expath.org/ns/binary}index-out-of-range"/>
    </result>
  </test-case>
  
  <test-case name="set-bits-009">
    <description>set-bits on four bytes</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:set-bits(bin:hex('F000F000'), 0, false())</test>
    <result>
      <assert-eq>bin:hex('7000F000')</assert-eq>
    </result>
  </test-case>
  
  <test-case name="set-bits-010">
    <description>set-bits on four bytes</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:set-bits(bin:hex('00010001'), 31, false())</test>
    <result>
      <assert-eq>bin:hex('00010000')</assert-eq>
    </result>
  </test-case>
  
  <test-case name="set-bits-011">
    <description>set-bits on four bytes</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:set-bits(bin:hex('F000F000'), (0 to 7, 16 to 23), true())</test>
    <result>
      <assert-eq>bin:hex('FF00FF00')</assert-eq>
    </result>
  </test-case>
  
  <test-case name="set-bits-012">
    <description>set-bits on four bytes</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:set-bits(bin:hex('00010001'), 30, true())</test>
    <result>
      <assert-eq>bin:hex('00010003')</assert-eq>
    </result>
  </test-case>
  
  <test-case name="set-bits-013">
    <description>set-bits on 32 bytes</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:set-bits(bin:hex('0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001'), (0 to 15)!(.*16 + 4), true())</test>
    <result>
      <assert-eq>bin:hex('0801_0801_0801_0801_0801_0801_0801_0801_0801_0801_0801_0801_0801_0801_0801_0801')</assert-eq>
    </result>
  </test-case>
  
  <test-case name="set-bits-014">
    <description>set-bits on 32 bytes</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:set-bits(bin:hex('0801_0801_0801_0801_0801_0801_0801_0801_0801_0801_0801_0801_0801_0801_0801_0801'), (0 to 15)!(.*16 + 4), false())</test>
    <result>
      <assert-eq>bin:hex('0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001')</assert-eq>
    </result>
  </test-case>
  
  <test-case name="set-bits-015">
    <description>set-bits on 32 bytes</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:set-bits(bin:hex('0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001'), 0 to 255, false())</test>
    <result>
      <assert-eq>bin:hex('0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000')</assert-eq>
    </result>
  </test-case>
  
  <test-case name="set-bits-016">
    <description>set-bits on 32 bytes</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test> bin:set-bits(bin:hex('0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001_0001'), (0 to 15)!(.*16), true())</test>
    <result>
      <assert-eq>bin:hex('8001_8001_8001_8001_8001_8001_8001_8001_8001_8001_8001_8001_8001_8001_8001_8001')</assert-eq>
    </result>
  </test-case>
  
  <test-case name="set-bits-017">
    <description>set-bits on 4096 bytes</description>
    <created by="Michael Kay" on="2026-06-19"/>
    <environment ref="EXPath-binary-bitwise"/>
    <test>
      let $bbb := bin:join(for $i in 1 to 1024 return bin:pack-integer($i, 4))
      let $ccc := bin:set-bits($bbb, for $i in 0 to 1023 return $i*32 + 31, true())
      let $ddd := for $i in 0 to 1023 return bin:unpack-integer($ccc, $i*4, 4)
      return $ddd[1, 2, 3, 4, last()]
    </test>
    <result>
      <assert-deep-eq>1, 3, 3, 5, 1025</assert-deep-eq>
    </result>
  </test-case>
  
</test-set>