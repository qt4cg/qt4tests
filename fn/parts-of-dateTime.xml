	<test-case name="fn-parts-of-dateTime-round-trip">
		<description>Test round tripping</description>
		<created by="Michael Kay" on="2026-03-12"/>
		<test>current-dateTime() => fn:parts-of-dateTime() => build-dateTime() => atomic-equal(current-dateTime())</test>
		<result>
			<assert-true/>
		</result>
	</test-case>
	
	<test-case name="fn-parts-of-dateTime-round-trip-altered">
		<description>Test round tripping and alteration</description>
		<created by="Michael Kay" on="2026-03-12"/>
		<test>current-dateTime() 
			   => fn:parts-of-dateTime()
			   => map:remove("timezone")
			   => build-dateTime() 
			   => atomic-equal(current-dateTime() => adjust-dateTime-to-timezone(()))</test>
		<result>
			<assert-true/>
		</result>
	</test-case>

	<test-case name="fn-parts-of-dateTime-dayTimeDuration">
		<description>Evaluates fn:parts-of-dateTime when the sole argument supplied is an xs:dayTimeDuration, 
			which is not a valid datatype for the input value, even though it's the datatype used when 
			the timezone is stored in the record.</description>
		<created by="Sheila Thomson" on="2026-02-24"/>
		<test>fn:parts-of-dateTime(xs:dayTimeDuration("-PT5H"))</test>
		<result>
			<error code="XPTY0004" />
		</result>
	</test-case>
	
