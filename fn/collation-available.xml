<?xml version="1.0" encoding="us-ascii"?>
<test-set xmlns="http://www.w3.org/2010/09/qt-fots-catalog" name="fn-collation-available" covers-40="PR2492">
   <description>Tests for the collation-available() function</description>
 
          
   <test-case name="collation-available-003">
      <description>Basic test with default collation</description>
      <created by="Michael Kay" on="2026-03-03"/>
      <test>collation-available(default-collation())</test>
      <result>
         <assert-true/>
      </result>
   </test-case>
   
    <test-case name="collation-available-005">
        <description>Simple comparison using codepoint collation explicitly</description>
        <created by="Michael Kay" on="2026-03-03"/>
        <test>collation-available("http://www.w3.org/2005/xpath-functions/collation/codepoint")
        </test>
        <result>
            <assert-true/>
        </result>
    </test-case>
    
    <test-case name="collation-available-006">
        <description>URI promotion works</description>
        <created by="Michael Kay" on="2013-10-04"/>
        <test>collation-available("http://www.w3.org/") eq collation-available(xs:anyURI("http://www.w3.org/"))</test>
        <result>
            <assert-true/>
        </result>
    </test-case>
    

   <test-case name="collation-available-008">
      <description>Simple comparison using a case-blind collation</description>
      <created by="Michael Kay" on="2026-03-03"/>
      <test>let $C := "http://www.w3.org/2013/collation/UCA?lang=en;strength=primary"
         return collation-available($C)
      </test>
      <result>
         <assert-true/>
      </result>
   </test-case>
   
   
   <test-case name="collation-available-010">
      <description>Equality comparison using the HTML case-blind collation</description>
      <created by="Michael Kay" on="2026-03-03"/>
      <test>let $C := "http://www.w3.org/2005/xpath-functions/collation/html-ascii-case-insensitive"
         return collation-available($C)
      </test>
      <result>
         <assert-true/>
      </result>
   </test-case>

   <test-case name="collation-available-011">
      <description>Basic test with case-blind, accent-blind collation</description>
      <created by="Michael Kay" on="2026-03-03"/>
      <test>
        let $c := "http://www.w3.org/2013/collation/UCA?strength=primary" return
        collation-available($c)</test>
      <result>
         <assert-true/>
      </result>
   </test-case> 
   
    
    <test-case name="collation-available-901">
        <description>Argument must be a string</description>
        <created by="Michael Kay" on="2026-03-03"/>
        <test>collation-available(123)</test>
        <result>
            <error code="XPTY0004"/>
        </result>
    </test-case>
   
   <test-case name="collation-available-902">
        <description>Probably not available</description>
        <created by="Michael Kay" on="2026-03-03"/>
        <test>collation-available("ftp://not-a-collation/")</test>
        <result>
            <assert-false/>
        </result>
    </test-case>
    
    

</test-set>
