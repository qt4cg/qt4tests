<test-set xmlns="http://www.w3.org/2010/09/qt-fots-catalog" name="fn-pad-string" covers-40="PR2784">
  <description>Tests for the fn:pad-string function</description>

  <link type="spec" document="https://qt4cg.org/specifications/xpath-functions-40/"
        idref="func-pad-string"/>

  <dependency type="spec" value="XP40+ XQ40+"/>

  <test-case name="pad-string-001">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test>fn:pad-string("abc", 5)</test>
    <result>
      <assert-eq>"abc  "</assert-eq>
    </result>
  </test-case>

  <test-case name="pad-string-002">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test>fn:pad-string("abc", 5, ())</test>
    <result>
      <assert-eq>"abc  "</assert-eq>
    </result>
  </test-case>

  <test-case name="pad-string-003">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test>fn:pad-string("abc", 5, { 'side': 'end' })</test>
    <result>
      <assert-eq>"abc  "</assert-eq>
    </result>
  </test-case>

  <test-case name="pad-string-004">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test>fn:pad-string("abc", 5, { 'side': 'start' })</test>
    <result>
      <assert-eq>"  abc"</assert-eq>
    </result>
  </test-case>

  <test-case name="pad-string-005">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test>fn:pad-string("abc", 5, { 'side': 'both' })</test>
    <result>
      <assert-eq>" abc "</assert-eq>
    </result>
  </test-case>

  <test-case name="pad-string-006">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test>fn:pad-string("abc", 6, { 'side': 'both' })</test>
    <result>
      <assert-eq>" abc  "</assert-eq>
    </result>
  </test-case>

  <test-case name="pad-string-007">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test>fn:pad-string("abc", 10, { 'padding': '-=' })</test>
    <result>
      <assert-eq>"abc-=-=-=-"</assert-eq>
    </result>
  </test-case>

  <test-case name="pad-string-008">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test>fn:pad-string("abc", 5, { 'padding': 'xyz' })</test>
    <result>
      <assert-eq>"abcxy"</assert-eq>
    </result>
  </test-case>

  <test-case name="pad-string-009">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test>fn:pad-string("abc", 9, { 'side': 'both', 'padding': '12' })</test>
    <result>
      <assert-eq>"121abc121"</assert-eq>
    </result>
  </test-case>

  <test-case name="pad-string-010">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test><![CDATA[fn:pad-string("abc", 8, { 'side': 'start', 'padding': '<>' })]]></test>
    <result>
      <assert-eq><![CDATA["<><><abc"]]></assert-eq>
    </result>
  </test-case>

  <test-case name="pad-string-011">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test>fn:pad-string("abcdef", 3)</test>
    <result>
      <assert-eq>"abcdef"</assert-eq>
    </result>
  </test-case>

  <test-case name="pad-string-012">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test>fn:pad-string("abc", 0)</test>
    <result>
      <assert-eq>"abc"</assert-eq>
    </result>
  </test-case>

  <test-case name="pad-string-013">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test>fn:pad-string("abc", -5)</test>
    <result>
      <assert-eq>"abc"</assert-eq>
    </result>
  </test-case>

  <test-case name="pad-string-014">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test>fn:pad-string((), 4, { 'padding': 'ab' })</test>
    <result>
      <assert-eq>"abab"</assert-eq>
    </result>
  </test-case>

  <test-case name="pad-string-015">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test>fn:pad-string(42, 6, { 'padding': '0', 'side': 'start' })</test>
    <result>
      <assert-eq>"000042"</assert-eq>
    </result>
  </test-case>

  <test-case name="pad-string-016">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test>fn:pad-string(xs:double(1.5), 6, { 'padding': '0' })</test>
    <result>
      <assert-eq>"1.5000"</assert-eq>
    </result>
  </test-case>

  <test-case name="pad-string-017">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test>fn:pad-string(true(), 6, { 'padding': '.' })</test>
    <result>
      <assert-eq>"true.."</assert-eq>
    </result>
  </test-case>

  <test-case name="pad-string-018">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test><![CDATA[fn:pad-string(fn:parse-xml("<a>x</a>")/a, 4, { 'padding': '.' })]]></test>
    <result>
      <assert-eq>"x..."</assert-eq>
    </result>
  </test-case>

  <test-case name="pad-string-019">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test>fn:string-to-codepoints(fn:pad-string(fn:char(128512), 3, { 'padding': '.' }))</test>
    <result>
      <assert-deep-eq>128512, 46, 46</assert-deep-eq>
    </result>
  </test-case>

  <test-case name="pad-string-020">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test>fn:string-to-codepoints(fn:pad-string("ab", 4, { 'padding': fn:char(128512) }))</test>
    <result>
      <assert-deep-eq>97, 98, 128512, 128512</assert-deep-eq>
    </result>
  </test-case>

  <test-case name="pad-string-021">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test>fn:pad-string("abc", 6, { 'padding': '' })</test>
    <result>
      <error code="FORG0001"/>
    </result>
  </test-case>

  <test-case name="pad-string-022">
    <description>Evaluation of the pad-string function.</description>
    <created by="Christian Gruen" on="2026-07-14"/>
    <test>fn:pad-string("abc", 6, { 'side': 'middle' })</test>
    <result>
      <error code="XPTY0004"/>
    </result>
  </test-case>

</test-set>
