   <test-case name="matching-segments-017">
      <description> subtle distinction in the positioning of an empty captured group </description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>matching-segments("banana", "(b)(x?)")</test>
      <result>
         <assert-deep-eq>
            {"substring": "b", "position": 1, "groups":{1: {"group": "b", "position": 1}, 
                                                        2: {"group": "", "position": 2}}}
         </assert-deep-eq>   
      </result>
   </test-case>
   
   <test-case name="matching-segments-017a">
      <description> No distinction in the positioning of an empty captured group</description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>matching-segments("banana", "(b(x?))")</test>
      <result>
         <assert-deep-eq>
            {"substring": "b", "position": 1, "groups":{1: {"group": "b", "position": 1}, 
                                                        2: {"group": "", "position": 2}}}
         </assert-deep-eq>   
      </result>
   </test-case>
   
   <test-case name="matching-segments-018">
      <description> non-capturing group indicated by "(?:...)" </description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>matching-segments("banana", "(?:b(an)*a)")</test>
      <result>
         <assert-deep-eq>
            {"substring": "banana", "position": 1, "groups":{1: {"group": "an", "position": 4}}} 
         </assert-deep-eq>
      </result>
   </test-case>
   
   <test-case name="matching-segments-019">
      <description> "q" flag suppresses grouping</description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>matching-segments("((banana))", "(banana)", "q")</test>
      <result>
         <assert-deep-eq>
            {"substring": "(banana)", "position": 2, "groups":{}} 
         </assert-deep-eq>
      </result>
   </test-case>
   
  
   
   <test-case name="matching-segments-020" covers-40="PR2717">
      <description>matching-segments with named captured groups.</description>
      <created by="Christian Gruen" on="2026-07-10"/>
      <test><![CDATA[matching-segments("banana", "a(?<letter>n)")]]></test>
      <result>
         <assert-deep-eq>
            {"substring":"an", "position":2, "groups":{"letter": {"group":"n", "position": 3}}},
            {"substring":"an", "position":4, "groups":{"letter": {"group":"n", "position": 5}}}
         </assert-deep-eq>
      </result>
   </test-case>

   <test-case name="matching-segments-021" covers-40="PR2717">
      <description>matching-segments with named captured groups.</description>
      <created by="Christian Gruen" on="2026-07-10"/>
      <test><![CDATA[matching-segments("2026-06-25", "(\d{4})-(?<month>\d{2})-(\d{2})")]]></test>
      <result>
         <all-of>
            <assert-deep-eq>
               {"substring":"2026-06-25", "position":1,
                "groups":{1: {"group":"2026", "position":1},
                          "month": {"group":"06", "position":6},
                          3: {"group":"25", "position":9}}}
            </assert-deep-eq>
            <assert>not(map:contains($result?groups, 2))</assert>
         </all-of>
      </result>
   </test-case>

   <test-case name="matching-segments-022" covers-40="PR2717">
      <description>matching-segments with named captured groups.</description>
      <created by="Christian Gruen" on="2026-07-10"/>
      <test><![CDATA[map:keys(matching-segments("2026-06-25", "(?<year>\d{4})-(?<month>\d{2})-(?<day>\d{2})")?groups)]]></test>
      <result>
         <assert-deep-eq>("year", "month", "day")</assert-deep-eq>
      </result>
   </test-case>

   <test-case name="matching-segments-023" covers-40="PR2717">
      <description>matching-segments with named captured groups.</description>
      <created by="Christian Gruen" on="2026-07-10"/>
      <test><![CDATA[matching-segments("2026-06-25", "(?<year>\d{4})-(?<month>\d{2})-(?<day>\d{2})")]]></test>
      <result>
         <assert-deep-eq>
            {"substring":"2026-06-25", "position":1,
             "groups":{"year": {"group":"2026", "position":1},
                       "month": {"group":"06", "position":6},
                       "day": {"group":"25", "position":9}}}
         </assert-deep-eq>
      </result>
   </test-case>

   <test-case name="matching-segments-024" covers-40="PR2717">
      <description>matching-segments with named captured groups.</description>
      <created by="Christian Gruen" on="2026-07-10"/>
      <test><![CDATA[matching-segments("how now", "(?<h>how)|(?<n>now)")]]></test>
      <result>
         <assert-deep-eq>
            {"substring":"how", "position":1, "groups":{"h": {"group":"how", "position":1}}},
            {"substring":"now", "position":5, "groups":{"n": {"group":"now", "position":5}}}
         </assert-deep-eq>
      </result>
   </test-case>

   <test-case name="matching-segments-025" covers-40="PR2717">
      <description>matching-segments with named captured groups.</description>
      <created by="Christian Gruen" on="2026-07-10"/>
      <test><![CDATA[matching-segments("Chapter 17", "(?<kind>Chapter|Appendix)\s+(?=(?<num>\d+))")]]></test>
      <result>
         <assert-deep-eq>
            {"substring":"Chapter ", "position":1,
             "groups":{"kind": {"group":"Chapter", "position":1},
                       "num": {"group":"17", "position":9}}}
         </assert-deep-eq>
      </result>
   </test-case>

   <test-case name="matching-segments-029">
      <description> Matching groups within repeated clause </description>
      <created by="Michael Kay" on="2026-06-08"/>
      <modified by="Gunther Rademacher" on="2026-07-09" change="XQuery only (direct constructor)"/>
      <dependency type="spec" value="XQ40+"/>
      <test><![CDATA[
         let $data :=
           <Root>
             <DATA>/OPDH/FLOWING SOLUTION/SGDE/Number0983713/EKPH/Sample test/some other keys/</DATA>
             <DATA>/some other keys/afdsf/SGDE/Number0983713/some other keys/PIHSAGA/OPDH/FLOWING SOLUTION/some other keys/No exception/EKPH/Sample test/some other keys/</DATA>
           </Root>
         return 
           $data/DATA!matching-segments(., '(/OPDH/|/EKPH/|/SGDE/|/some other keys/)(.*?)(/OPDH/|/EKPH/|/SGDE/|/some other keys/)((.*?)(/OPDH/|/EKPH/|/SGDE/|/some other keys/))*')
          
      ]]></test>
      <result>
         <all-of>
            <assert>$result[1]?groups?1?group = '/OPDH/'</assert>
            <assert>$result[1]?groups?2?group = 'FLOWING SOLUTION'</assert>
            <assert>$result[1]?groups?3?group = '/SGDE/'</assert>
            <assert>$result[1]?groups?4?group = 'Sample test/some other keys/'</assert>
            <assert>$result[2]?groups?1?group = '/some other keys/'</assert>
            <assert>$result[2]?groups?2?group = 'afdsf'</assert>
            <assert>$result[2]?groups?3?group = '/SGDE/'</assert>
            <assert>$result[2]?groups?4?group = 'Sample test/some other keys/'</assert>
         </all-of>
      </result>
   </test-case>
   
   <test-case name="matching-segments-030">
      <description> Comment in regular expression [for more tests see fn:replace]</description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>fn:matching-segments(concat('Mary', char(13), 'Jones'), 'y#dot#.#dot#J', 'sc')?substring</test>
      <result>
         <assert-eq>concat('y', char(13), 'J')</assert-eq>
      </result>
   </test-case>
   
   <test-case name="matching-segments-031">
      <description>Empty Pattern</description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>fn:matching-segments("abc", "")</test>
      <result>
         <assert-deep-eq>
            {"substring": "", "position": 1, "groups":{}},
            {"substring": "", "position": 2, "groups":{}},
            {"substring": "", "position": 3, "groups":{}},
            {"substring": "", "position": 4, "groups":{}}
         </assert-deep-eq> 
      </result>
   </test-case>
   
   <test-case name="matching-segments-032">
      <description>Captured group in lookahead</description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>fn:matching-segments("abcd", ".(?=(.))")</test>
      <result>
         <assert-deep-eq>
            {"substring": "a", "position": 1, "groups":{1: {"group": "b", "position": 2}}},
            {"substring": "b", "position": 2, "groups":{1: {"group": "c", "position": 3}}},
            {"substring": "c", "position": 3, "groups":{1: {"group": "d", "position": 4}}}
         </assert-deep-eq>
      </result>
   </test-case>
   
   <test-case name="matching-segments-033">
      <description>Both ordinary and lookahead captured groups present</description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>fn:matching-segments("Chapter 17", "(Chapter|Appendix)\s+(?=(\d+))")</test>
      <result>
         <assert-deep-eq>
            {"substring": "Chapter ", "position": 1, "groups": {1: {"group": "Chapter", "position": 1},
                                                                2: {"group": "17", "position": 9}} }
         </assert-deep-eq>
      </result>
   </test-case>
   
   <test-case name="matching-segments-034">
      <description>Multiple lookahead captured groups present</description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>fn:matching-segments("Chapter 17c", "(Chapter|Appendix)\s+(?=(\d+)([a-z])?)")</test>
      <result>
         <assert-deep-eq>
            {"substring": "Chapter ", "position": 1, "groups": {1: {"group": "Chapter", "position": 1},
                                                                2: {"group": "17", "position": 9},
                                                                3: {"group": "c", "position": 11} } }
         </assert-deep-eq>
      </result>
   </test-case>
   
   <test-case name="matching-segments-035">
      <description>Zero-length lookahead captured groups present</description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>fn:matching-segments("Chapter 17", "(Chapter|Appendix)\s+(?=(\d+)([a-z]?))")</test>
      <result>
         <assert-deep-eq>
            {"substring": "Chapter ", "position": 1, "groups": {1: {"group": "Chapter", "position": 1},
                                                                2: {"group": "17", "position": 9},
                                                                3: {"group": "", "position": 11} } }
         </assert-deep-eq>
         <!--<assert-xml ignore-prefixes="true"><![CDATA[<matching-segments-result xmlns="http://www.w3.org/2005/xpath-functions">
   <match><group nr="1">Chapter</group> <lookahead-group nr="2" position="9" value="17"/><lookahead-group nr="3" position="11" value=""/></match>
   <non-match>17</non-match>
</matching-segments-result>]]></assert-xml>-->
      </result>
   </test-case>
   
   
   
   <test-case name="matching-segments-901">
      <description> matching-segments, error, bad regex pattern</description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>matching-segments("abc", ")-(")</test>
      <result>
            <error code="FORX0002"/>
      </result>
   </test-case>
   
   <test-case name="matching-segments-902">
      <description> matching-segments, error, bad flags </description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>matching-segments("abc", "abc", "w")</test>
      <result>
            <error code="FORX0001"/>
      </result>
   </test-case>
   
   <test-case name="matching-segments-904">
      <description> matching-segments, pattern matches a zero-length string </description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>matching-segments("abc", "a|b|c?")</test>
      <result>
         <all-of>
            <assert>$result[1]?substring = 'a'</assert>
            <assert>$result[2]?substring = 'b'</assert>
            <assert>$result[3]?substring = 'c'</assert>
            <assert>$result[4]?substring = ''</assert>
            <assert>count($result) = 4</assert>
         </all-of>
      </result>
   </test-case>
</test-set>
