<?xml version="1.0" encoding="UTF-8"?>
<test-set xmlns="http://www.w3.org/2010/09/qt-fots-catalog" name="fn-matching-segments" covers-40="PR2470">
   <description>Tests for the matching-segments function</description>

   <dependency type="spec" value="XP40+ XQ40+"/>      

 

   <test-case name="matching-segments-001">
      <description> matching-segments with empty string</description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>matching-segments("", "abc")</test>
      <result>
         <assert-deep-eq>()</assert-deep-eq>
      </result>
   </test-case>
   
   <test-case name="matching-segments-002" covers-40="PR2658">
      <description> matching-segments with empty sequence </description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>matching-segments((), "abc")</test>
      <result>
         <assert-deep-eq>()</assert-deep-eq>
      </result>
   </test-case>
   
   <test-case name="matching-segments-002a">
      <description> matching-segments with empty sequence </description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>count(matching-segments((), "abc"))</test>
      <result>
         <assert-eq>0</assert-eq>
      </result>
   </test-case>
   
   <test-case name="matching-segments-003">
      <description> matching-segments with a mix of matching and non-matching strings</description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>matching-segments("banana", "a")</test>
      <result>
         <assert-deep-eq>
            {"substring":"a", "position":2, "groups":{}},
            {"substring":"a", "position":4, "groups":{}},
            {"substring":"a", "position":6, "groups":{}}
         </assert-deep-eq>
      </result>
   </test-case>
   
   <test-case name="matching-segments-004">
      <description> matching-segments with a single non-matching string</description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>matching-segments("banana", "custard")</test>
      <result>
         <assert-empty/>
      </result>
   </test-case>
   
   <test-case name="matching-segments-005">
      <description> matching-segments with a single matching string</description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>matching-segments("banana", ".+")</test>
      <result>
         <assert-deep-eq>
            {"substring":"banana", "position":1, "groups":{}}
         </assert-deep-eq>
      </result>
   </test-case>
   
   <test-case name="matching-segments-006">
      <description> matching-segments with a adjacent matching strings</description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>matching-segments("banana", "an")</test>
      <result>
         <assert-deep-eq>
            {"substring":"an", "position":2, "groups":{}},
            {"substring":"an", "position":4, "groups":{}}
         </assert-deep-eq>
      </result>
   </test-case>
   
   <test-case name="matching-segments-007">
      <description> matching-segments with a single captured group</description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>matching-segments("banana", "a(n)")</test>
      <result>
         <assert-deep-eq>
            {"substring":"an", "position":2, "groups":{1: {"group":"n", "position": 3}}},
            {"substring":"an", "position":4, "groups":{1: {"group":"n", "position": 5}}}
         </assert-deep-eq>
      </result>
   </test-case>
   
   <test-case name="matching-segments-008">
      <description> matching-segments with nested captured groups</description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>matching-segments("banana", "(a(n?))")</test>
      <result>
         <assert-deep-eq>
            {"substring":"an", "position":2, "groups":{1: {"group":"an", "position": 2}, 2: {"group":"n", "position": 3}}},
            {"substring":"an", "position":4, "groups":{1: {"group":"an", "position": 4}, 2: {"group":"n", "position": 5}}},
            {"substring":"a", "position":6, "groups":{1: {"group":"a", "position": 6}, 2: {"group":"", "position": 7}}}
         </assert-deep-eq>
      </result>
   </test-case>
   
   <test-case name="matching-segments-009">
      <description> matching-segments, groups in alternatives </description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>matching-segments("how now brown cow", "(how)|(now)|(brown)|(cow)")</test>
      <result>
         <assert-deep-eq>
            {"substring":"how", "position":1, "groups":{1: {"group":"how", "position": 1}}},
            {"substring":"now", "position":5, "groups":{2: {"group":"now", "position": 5}}},
            {"substring":"brown", "position":9, "groups":{3: {"group":"brown", "position": 9}}},
            {"substring":"cow", "position":15, "groups":{4: {"group":"cow", "position": 15}}}
         </assert-deep-eq>
      </result>
   </test-case>
   
   <test-case name="matching-segments-010">
      <description> matching-segments, with i flag </description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>matching-segments("how now brown cow", "(HOW)|(NOW)|(BROWN)|(COW)", "i")</test>
      <result>
         <assert-deep-eq>
            {"substring":"how", "position":1, "groups":{1: {"group":"how", "position": 1}}},
            {"substring":"now", "position":5, "groups":{2: {"group":"now", "position": 5}}},
            {"substring":"brown", "position":9, "groups":{3: {"group":"brown", "position": 9}}},
            {"substring":"cow", "position":15, "groups":{4: {"group":"cow", "position": 15}}}
         </assert-deep-eq>
      </result>
   </test-case>
   
   <test-case name="matching-segments-011">
      <description> matching-segments, with i and x flag </description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>matching-segments("how now brown cow", " (HOW) | (NOW) &#xa;| (BROWN) | (COW) ", "ix")</test>
      <result>
         <assert-deep-eq>
            {"substring":"how", "position":1, "groups":{1: {"group":"how", "position": 1}}},
            {"substring":"now", "position":5, "groups":{2: {"group":"now", "position": 5}}},
            {"substring":"brown", "position":9, "groups":{3: {"group":"brown", "position": 9}}},
            {"substring":"cow", "position":15, "groups":{4: {"group":"cow", "position": 15}}}
         </assert-deep-eq>
      </result>
   </test-case>
   
   <test-case name="matching-segments-012">
      <description> matching-segments, with flags set to empty string</description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>matching-segments("how now brown cow", "(.*?ow\s+)+", "")</test>
      <result>
         <assert-deep-eq>
            {"substring":"how now ", "position":1, "groups":{1: {"group":"now ", "position": 5}}}
         </assert-deep-eq>
      </result>
   </test-case>
   
   <test-case name="matching-segments-013">
      <description> matching-segments, with "s" flag</description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>let $in := 
"Mary had a little lamb,
its fleece was black as soot,
and everywhere that Mary went,
it put its sooty foot."
            return matching-segments($in, "Mary.*foot", "s")</test>
      <result>
         <assert-deep-eq>
            {"substring":"Mary had a little lamb,
its fleece was black as soot,
and everywhere that Mary went,
it put its sooty foot", "position":1, "groups":{}}
         </assert-deep-eq>
      </result>
   </test-case>
   
   <test-case name="matching-segments-014">
      <description> matching-segments, multiple lines without "s" flag </description>
      <created by="Michael Kay" on="2026-06-08"/>
      <test>let $in := 
"Mary had a little lamb,
its fleece was black as soot,
and everywhere that Mary went,
it put its sooty foot."
            return matching-segments($in, ".+", "")</test>
      <result>
         <assert-deep-eq>
            {"substring": "Mary had a little lamb,", "position": 1, "groups":{}},
            {"substring": "its fleece was black as soot,", "position": 25, "groups":{}},
            {"substring": "and everywhere that Mary went,", "position": 55, "groups":{}},
            {"substring": "it put its sooty foot.", "position": 86, "groups":{}}
         </assert-deep-eq>        
      </result>
   </test-case>
   
   <test-case name="matching-segments-015">
      <description> matching-segments, multiple lines with "m" flag </description>
      <created by="Michael Kay" on="2026-06-08"/>
